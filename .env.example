# Optional overrides; use __ between nested configuration fields. Do not commit .env.
# Values are read from the process environment; this project does not load .env files.
AURORA_LOGGING__LEVEL=DEBUG
AURORA_WLED__ENABLED=false
AURORA_WLED__HOST=
AURORA_WLED__PORT=
AURORA_WLED__VALIDATION_TIMEOUT_SECONDS=2.0
AURORA_HYPERHDR__VALIDATION_TIMEOUT_SECONDS=2.0
AURORA_MQTT__USERNAME=
AURORA_MQTT__PASSWORD=
